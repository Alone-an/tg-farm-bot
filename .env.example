# Telegram 凭据，在 https://my.telegram.org 申请
TG_API_ID=
TG_API_HASH=

# 抓包后填入：Mini App 页面地址（用于过 CF 验证）
MINI_APP_URL=

# 抓包后填入：接口根地址，不含末尾斜杠，例如 https://api.example.com
BASE_API_URL=

# ⚠️ Telegram 登录态(base64 的 .session)请勿写进本文件！
# 它约 38KB，超过 Windows 单个环境变量 32767 字符上限，会让 load_dotenv() 崩溃。
#   本地：放到独立文件 .session_string（或用 TG_SESSION_FILE 指定路径）。
#   云端：作为 Secret 注入名为 TG_SESSION 的环境变量（Linux 无长度限制）。

