# ============================================================
#  复制本文件为 .env，填好下面两个值即可。游戏接口已内置，无需改。
# ============================================================

# Telegram API 凭据 —— 去 https://my.telegram.org 免费申请（每个人用自己的）
TG_API_ID=
TG_API_HASH=

# （可选）连 Telegram 需要代理时填，例如 socks5://127.0.0.1:10808
# 能直连 Telegram 的网络可留空 / 删掉本行
TG_PROXY=

# ------------------------------------------------------------
# ⚠️ Telegram 登录态不要写在这里！
#   首次运行 `python main.py` 会让你用手机号 + 验证码登录，
#   自动生成 .session_string 文件，之后免登录。
#
# 进阶（一般用不到）：以下默认指向目标游戏，换游戏才需覆盖。
#   BOT_USERNAME=     目标 bot username（不含 @）
#   MINI_APP_URL=     Mini App 页面地址
#   BASE_API_URL=     REST 接口根地址（不含末尾斜杠）
#   WS_URL=           WebSocket 地址
# ------------------------------------------------------------
